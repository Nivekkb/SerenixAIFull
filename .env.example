# Gemini API key for local web app usage.
# Preferred for Vite frontend:
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"
# Backward-compatible fallback (also supported):
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional: SELF governance service URLs (pre/post safety pipeline).
# If both pre and post are on the same server, set only VITE_SELF_GOVERNANCE_URL.
# If you split pre/post across services, set PRE and POST explicitly.
# Local package wrapper default (this repo): http://localhost:8788
# External SELF HTTP service default: http://localhost:8787
VITE_SELF_GOVERNANCE_URL="http://localhost:8788"
VITE_SELF_GOVERNANCE_PRE_URL=""
VITE_SELF_GOVERNANCE_POST_URL=""
# Optional: dedicated base URL for shared circle endpoints (/v1/circles/*).
VITE_SELF_GOVERNANCE_CIRCLE_URL=""
# If the governance service requires auth, set the same key here.
VITE_SELF_GOVERNANCE_API_KEY=""
# Optional timeout (ms) for each SELF call.
VITE_SELF_GOVERNANCE_TIMEOUT_MS="1200"

# Optional Firebase Admin credentials for trusted server-side circle AI writes.
# Use either application default credentials (for example GOOGLE_APPLICATION_CREDENTIALS)
# or set the explicit service account fields below for local development.
GOOGLE_APPLICATION_CREDENTIALS=""
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
# Optional invite hardening knobs for shared circles.
# Invite codes are generated/validated by governance server endpoints.
CIRCLE_INVITE_TTL_HOURS="168"
CIRCLE_INVITE_RATE_LIMIT_WINDOW_SECONDS="60"
CIRCLE_INVITE_RATE_LIMIT_MAX_ATTEMPTS="10"

# Optional: SELF semantic assist (ML scores assist state detection, governance stays deterministic).
# Keep disabled by default until you are ready to evaluate.
SELF_SEMANTIC_ASSIST_ENABLED="false"
# "assist" applies bounded escalation rules from semantic scores.
# "observe" logs semantic scores/reasons but does not change state.
SELF_SEMANTIC_ASSIST_MODE="assist"
# Optional provider keys for semantic assist model scoring.
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
