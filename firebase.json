{
  "firestore": {
    "database": "(default)",
    "location": "northamerica-northeast2",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "site": "serenixai-f0e1f-abb71",
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "frameworksBackend": {
      "region": "us-west1"
    },
    "rewrites": [
      {
        "source": "/v1/pre",
        "run": {
          "serviceId": "serenix-governance",
          "region": "us-west1"
        }
      },
      {
        "source": "/v1/post",
        "run": {
          "serviceId": "serenix-governance",
          "region": "us-west1"
        }
      },
      {
        "source": "/v1/circles/**",
        "run": {
          "serviceId": "serenix-governance",
          "region": "us-west1"
        }
      },
      {
        "source": "/health-governance",
        "run": {
          "serviceId": "serenix-governance",
          "region": "us-west1"
        }
      }
    ]
  },
  "auth": {
    "providers": {
      "emailPassword": true,
      "googleSignIn": {
        "oAuthBrandDisplayName": "SerenixAI",
        "supportEmail": "Kevin@serenixdigital.com"
      }
    }
  }
}
