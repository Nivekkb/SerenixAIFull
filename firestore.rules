rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, displayName, email, photoURL, createdAt
    //
    // Collection: circles
    // Fields: name, description, createdBy, members, createdAt
    //
    // Subcollection: circles/{circleId}/messages
    // Fields: content, senderId, senderName, timestamp, type
    //
    // Subcollection: private_chats/{userId}/messages
    // Fields: content, senderId, senderName, timestamp, type
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return data.uid is string && 
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.email is string &&
             data.createdAt is string;
    }

    function isValidCircle(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.createdBy is string &&
             data.members is list &&
             data.createdAt is string;
    }

    function isValidMessage(data) {
      return data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.senderId is string &&
             data.senderName is string &&
             data.timestamp is string &&
             data.type in ['text', 'ai'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /circles/{circleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidCircle(request.resource.data) && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && isValidCircle(request.resource.data) && (
        request.auth.uid == resource.data.createdBy || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) && request.auth.uid in request.resource.data.members)
      );
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/circles/$(circleId)).data.members;
        allow create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/circles/$(circleId)).data.members && isValidMessage(request.resource.data);
      }
    }

    match /private_chats/{userId} {
      match /messages/{messageId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidMessage(request.resource.data);
      }
    }
  }
}
