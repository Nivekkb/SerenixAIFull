rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, displayName, email, photoURL, createdAt
    //
    // Collection: circles
    // Fields: name, description, createdBy, members, createdAt
    //
    // Subcollection: circles/{circleId}/messages
    // Fields: content, senderId, senderName, timestamp, type
    //
    // Subcollection: private_chats/{userId}/messages
    // Fields: content, senderId, senderName, timestamp, type
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return data.uid is string && 
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.email is string &&
             (!data.keys().hasAny(['preferredName']) || data.preferredName == null || (data.preferredName is string && data.preferredName.size() <= 80)) &&
             (!data.keys().hasAny(['responseLength']) || data.responseLength in ['short', 'medium', 'long']) &&
             (!data.keys().hasAny(['chatRetentionMode']) || data.chatRetentionMode in ['ephemeral', 'persistent']) &&
             (!data.keys().hasAny(['sensitiveDataConsentAt']) || data.sensitiveDataConsentAt == null || data.sensitiveDataConsentAt is string) &&
             (data.createdAt is string || data.createdAt is timestamp);
    }

    function isValidCircle(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!data.keys().hasAny(['description']) || (data.description is string && data.description.size() < 500)) &&
             data.createdBy is string &&
             data.members is list &&
             (!data.keys().hasAny(['inviteCode']) || (data.inviteCode is string && data.inviteCode.size() >= 6 && data.inviteCode.size() <= 32)) &&
             (!data.keys().hasAny(['aiPresence']) || data.aiPresence in ['quiet', 'facilitation', 'reflection']) &&
             (data.createdAt is string || data.createdAt is timestamp);
    }

    function isValidMessage(data) {
      return data.keys().hasOnly(['content', 'senderId', 'senderName', 'timestamp', 'type']) &&
             data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.senderId is string &&
             data.senderName is string &&
             (data.timestamp is string || data.timestamp is timestamp) &&
             data.type == 'text';
    }

    function isCircleMember(circleId) {
      return isAuthenticated()
        && request.auth.uid in get(/databases/$(database)/documents/circles/$(circleId)).data.members;
    }

    function isSelfJoinCircleMembersUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
        && request.auth.uid in request.resource.data.members
        && !(request.auth.uid in resource.data.members)
        && request.resource.data.members.size() == resource.data.members.size() + 1
        && request.resource.data.members.hasAll(resource.data.members);
    }

    function isSelfTextMessageWrite() {
      return request.resource.data.senderId == request.auth.uid
        && request.resource.data.type == 'text';
    }

    function isValidCircleInvite(data) {
      return data.circleId is string &&
             data.inviteCode is string && data.inviteCode.size() >= 6 && data.inviteCode.size() <= 32 &&
             data.createdBy is string &&
             (data.createdAt is string || data.createdAt is timestamp);
    }

    function isValidTypingStatus(data, userId) {
      return data.keys().hasOnly(['userId', 'displayName', 'typing', 'updatedAt']) &&
             data.userId == userId &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 120 &&
             data.typing is bool &&
             (data.updatedAt is string || data.updatedAt is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /circles/{circleId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.members;
      allow create: if isAuthenticated()
        && isValidCircle(request.resource.data)
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated()
        && isValidCircle(request.resource.data)
        && (
          (
            request.auth.uid == resource.data.createdBy
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
              'inviteCode',
              'inviteExpiresAt',
              'inviteUpdatedAt',
              'inviteRevokedAt'
            ])
          )
          || isSelfJoinCircleMembersUpdate()
        );
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.createdBy;
      
      match /messages/{messageId} {
        allow read: if isCircleMember(circleId);
        allow create: if isCircleMember(circleId) && isValidMessage(request.resource.data) && isSelfTextMessageWrite();
        allow delete: if isCircleMember(circleId) && resource.data.senderId == request.auth.uid;
      }

      match /typing/{userId} {
        allow read: if isCircleMember(circleId);
        allow create, update: if isCircleMember(circleId)
          && request.auth.uid == userId
          && isValidTypingStatus(request.resource.data, userId);
        allow delete: if isCircleMember(circleId) && request.auth.uid == userId;
      }
    }

    match /circle_invites/{inviteCode} {
      allow read, write: if false;
    }

    match /private_chats/{userId} {
      match /messages/{messageId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidMessage(request.resource.data) && isSelfTextMessageWrite();
        allow delete: if isOwner(userId);
      }
    }
  }
}
