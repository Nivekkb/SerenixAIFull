{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:governance": "tsx server/governance-server.ts",
    "dev:governance:cloudrun": "node server/cloudrun/server.js",
    "dev:all": "concurrently --kill-others-on-fail \"npm:dev:governance\" \"npm:dev\"",
    "redteam:run": "tsx redteam/src/runner.ts",
    "redteam:mutate": "tsx redteam/src/mutate-cli.ts",
    "redteam:mutate:expansion": "tsx redteam/src/mutate-cli.ts --blueprint redteam/blueprints/self-mutation-blueprint.json --output redteam/datasets/generated.self.expansion.json --seed serenix-expansion-seed --mode both --scale 1.75",
    "redteam:mutate:expansion:v2": "tsx redteam/src/mutate-cli.ts --blueprint redteam/blueprints/self-mutation-blueprint.json --output redteam/datasets/generated.self.expansion.v2.json --seed serenix-expansion-v2-seed --mode both --scale 1.5",
    "redteam:mutate:holdout": "tsx redteam/src/mutate-cli.ts --blueprint redteam/blueprints/self-mutation-holdout-v1.json --output redteam/datasets/generated.self.holdout.json --seed serenix-holdout-seed --mode both",
    "redteam:mutate:hard-holdout": "tsx redteam/src/mutate-cli.ts --blueprint redteam/blueprints/self-mutation-hard-holdout-v1.json --output redteam/datasets/generated.self.hard-holdout.json --seed serenix-hard-holdout-seed --mode both",
    "redteam:stricten": "tsx redteam/src/strict-oracle-cli.ts",
    "redteam:prepare:mutations:strict-v2": "tsx redteam/src/strict-oracle-cli.ts --input redteam/datasets/generated.self.mutations.json --output redteam/datasets/generated.self.mutations.strict.v2.json",
    "redteam:run:mutations:strict-v2": "tsx redteam/src/runner.ts --mode both --dataset redteam/datasets/generated.self.mutations.strict.v2.json --durationMinutes 480 --variationProbability 0.35 --useLiveModel true",
    "redteam:edge:build": "tsx redteam/src/edge-filter-cli.ts",
    "redteam:prepare:edge-only": "npm run redteam:prepare:expansion:v2:strict && npm run redteam:edge:build -- --input redteam/datasets/generated.self.expansion.v2.strict.json --output redteam/datasets/generated.self.edge-only.v1.strict.json",
    "redteam:prepare:expansion:v2:strict": "npm run redteam:mutate:expansion:v2 && npm run redteam:stricten -- --input redteam/datasets/generated.self.expansion.v2.json --output redteam/datasets/generated.self.expansion.v2.strict.json",
    "redteam:prepare:overnight-strict": "npm run redteam:mutate:expansion && npm run redteam:mutate:hard-holdout && npm run redteam:stricten -- --input redteam/datasets/generated.self.expansion.json --output redteam/datasets/generated.self.expansion.strict.json && npm run redteam:stricten -- --input redteam/datasets/generated.self.hard-holdout.json --output redteam/datasets/generated.self.hard-holdout.strict.json",
    "redteam:ci": "tsx redteam/src/runner.ts --config redteam/config/redteam.ci.json",
    "redteam:holdout": "tsx redteam/src/runner.ts --config redteam/config/redteam.holdout.json",
    "redteam:hard-holdout": "tsx redteam/src/runner.ts --config redteam/config/redteam.hard-holdout.json",
    "redteam:integration-balance": "tsx redteam/src/runner.ts --config redteam/config/redteam.integration-balance.json",
    "redteam:live-soak": "tsx redteam/src/runner.ts --config redteam/config/redteam.live-soak.json",
    "redteam:clinician-overnight": "tsx redteam/src/runner.ts --config redteam/config/redteam.live-soak.json",
    "redteam:overnight:strict": "tsx redteam/src/runner.ts --config redteam/config/redteam.overnight.strict.json",
    "redteam:edge-only": "tsx redteam/src/runner.ts --config redteam/config/redteam.edge-only.json",
    "redteam:edge-hard-live": "tsx redteam/src/runner.ts --config redteam/config/redteam.edge-hard-live.json",
    "redteam:persistence-regression": "tsx redteam/src/runner.ts --config redteam/config/redteam.persistence-regression.json",
    "redteam:persistence-regression:live": "tsx redteam/src/runner.ts --config redteam/config/redteam.persistence-regression.json --useLiveModel true",
    "redteam:error-ledger": "tsx redteam/src/error-ledger-cli.ts",
    "redteam:report": "tsx redteam/src/report-cli.ts",
    "redteam:checkpoint": "tsx redteam/src/checkpoint-cli.ts",
    "test:transcript-export": "tsx scripts/test-transcript-export.ts",
    "release:smoke": "npm run test:transcript-export && npm run redteam:persistence-regression",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "self-engine": "file:../SELF/SELF",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
