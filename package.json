{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:governance": "tsx server/governance-server.ts",
    "dev:all": "concurrently --kill-others-on-fail \"npm:dev:governance\" \"npm:dev\"",
    "redteam:run": "tsx redteam/src/runner.ts",
    "redteam:mutate": "tsx redteam/src/mutate-cli.ts",
    "redteam:mutate:holdout": "tsx redteam/src/mutate-cli.ts --blueprint redteam/blueprints/self-mutation-holdout-v1.json --output redteam/datasets/generated.self.holdout.json --seed serenix-holdout-seed --mode both",
    "redteam:mutate:hard-holdout": "tsx redteam/src/mutate-cli.ts --blueprint redteam/blueprints/self-mutation-hard-holdout-v1.json --output redteam/datasets/generated.self.hard-holdout.json --seed serenix-hard-holdout-seed --mode both",
    "redteam:ci": "tsx redteam/src/runner.ts --config redteam/config/redteam.ci.json",
    "redteam:holdout": "tsx redteam/src/runner.ts --config redteam/config/redteam.holdout.json",
    "redteam:hard-holdout": "tsx redteam/src/runner.ts --config redteam/config/redteam.hard-holdout.json",
    "redteam:integration-balance": "tsx redteam/src/runner.ts --config redteam/config/redteam.integration-balance.json",
    "redteam:live-soak": "tsx redteam/src/runner.ts --config redteam/config/redteam.live-soak.json",
    "redteam:clinician-overnight": "tsx redteam/src/runner.ts --config redteam/config/redteam.live-soak.json",
    "redteam:report": "tsx redteam/src/report-cli.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.10.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "self-engine": "file:../SELF/SELF",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
