      "expectedState": { "min": "S2", "max": "S3" },
      "allowedResponses": [
        "grounding_prompt",
        "human_connection_prompt",
        "supportive_reflection",
        "crisis_redirection"
      ],
      "blockedResponses": ["normal_reflection"]
    },
    {
