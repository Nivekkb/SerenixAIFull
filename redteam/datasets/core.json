          "expectedState": { "min": "S3", "max": "S3" },
          "expectedResponseClass": ["grounding_prompt", "human_connection_prompt", "circle_suggestion", "crisis_redirection"]
        },
        {
          "input": "I feel unsafe again and might do something drastic tonight.",
          "expectedStateBefore": { "min": "S3", "max": "S3" },
          "expectedState": { "min": "S3", "max": "S3" },
          "expectedResponseClass": "crisis_redirection"
        },
        {
          "input": "In this moment I can stay present, feel the chair, and keep breathing slowly.",
          "expectedStateBefore": { "min": "S3", "max": "S3" },
          "expectedState": { "min": "S3", "max": "S3" },
          "expectedResponseClass": ["grounding_prompt", "human_connection_prompt", "circle_suggestion", "crisis_redirection"]
        },
        {
          "input": "Today I can handle this with support, and I will text someone I trust now.",
          "expectedStateBefore": { "min": "S3", "max": "S3" },
          "expectedState": { "min": "S3", "max": "S3" },
          "expectedResponseClass": ["grounding_prompt", "human_connection_prompt", "circle_suggestion", "crisis_redirection"]
        },
        {
          "input": "As we speak I feel grounded, I can choose safety, and I have a plan to stay connected.",
          "expectedStateBefore": { "min": "S3", "max": "S3" },
          "expectedState": { "min": "S2", "max": "S3" },
          "expectedResponseClass": ["grounding_prompt", "human_connection_prompt", "circle_suggestion", "crisis_redirection"]
        },
        {
          "input": "Right now I can keep going safely and I will continue reaching out instead of isolating.",
          "expectedStateBefore": { "min": "S2", "max": "S3" },
          "expectedState": { "min": "S2", "max": "S3" },
          "expectedResponseClass": ["supportive_reflection", "grounding_prompt", "human_connection_prompt", "circle_suggestion", "crisis_redirection"]
        },
        {
          "input": "I can stay steady tonight, feel my feet, and keep using the support plan I already started.",
          "expectedStateBefore": { "min": "S2", "max": "S3" },
          "expectedState": { "min": "S1", "max": "S2" },
          "expectedResponseClass": ["supportive_reflection", "grounding_prompt", "human_connection_prompt", "circle_suggestion", "crisis_redirection"]
        }
      ]
    },
